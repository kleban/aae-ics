                <DataGrid ItemsSource="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                          x:Name="membersDataGrid"
                          HorizontalAlignment="Left"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          AutoGenerateColumns="False"
                          ColumnWidth="*">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="C" CanUserResize="False" ElementStyle="{StaticResource CheckBoxStyle}">
                            <DataGridCheckBoxColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource CheckBoxStyle}"/>
                                </DataTemplate>
                            </DataGridCheckBoxColumn.HeaderTemplate>
                        </DataGridCheckBoxColumn>
                        
                        
                        <DataGridTextColumn Header="ЄДРПОУ" Binding="{Binding Edrpou}" />
                        <DataGridTextColumn Header="Особа, що затвердила" Binding="{Binding ApprovePerson}" />
                        <DataGridTextColumn Header="Дата затвердження" Binding="{Binding ApproveDate, StringFormat=\{0:dd.MM.yyyy\}}" />
                        <DataGridTextColumn Header="Дата реєстрації" Binding="{Binding RegistrationDate, StringFormat=\{0:dd.MM.yyyy\}}"  />
                        <DataGridTextColumn Header="Місце реєстрації" Binding="{Binding RegistrationPlace}"  />
                        <DataGridTextColumn Header="Дата початку передачі" Binding="{Binding TransferDateStart, StringFormat=\{0:dd.MM.yyyy\}}"  />
                        <DataGridTextColumn Header="Дата кінця передачі" Binding="{Binding TransferDateEnd, StringFormat=\{0:dd.MM.yyyy\}}"  />
                        <DataGridTextColumn Header="Донор" Binding="{Binding Donor}"  />
                        <DataGridTextColumn Header="Отримувач" Binding="{Binding Recipient}"  />
                        <DataGridTextColumn Header="Компанія доставки" Binding="{Binding DeliveryCompany}"  />
                        
                        
                        <DataGridTemplateColumn Header="Operations" IsReadOnly="True"  >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource GridEditButton}">
                                            <Icon:PackIconMaterial Kind="PencilOutline" Style="{StaticResource GridButtonIcon}"/>
                                        </Button>
                                        <Button Margin="5 0 0 0" Style="{StaticResource GridRemoveButton}">
                                            <Icon:PackIconMaterial Kind="DeleteOutline" Style="{StaticResource GridButtonIcon}"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
