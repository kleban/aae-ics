<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:helpers="clr-namespace:AAEICS.Client.Helpers">
    
    <Thickness x:Key="CardMarginLeft">0,0,5,10</Thickness>
    <Thickness x:Key="CardMarginCenter">5,0,5,10</Thickness>
    <Thickness x:Key="CardMarginRight">5,0,0,10</Thickness>
    
    <DataTemplate x:Key="DashboardCardDataTemplate">
        <Border Style="{StaticResource DashboardCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> 
                    <RowDefinition Height="*" />    
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />    
                    <ColumnDefinition Width="Auto" /> 
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource DashboardTitleStyle}">
                    <TextBlock Text="{Binding CardTitle}" FontWeight="SemiBold" />
                </Border>

                <ContentControl Grid.Row="0" Grid.Column="1"
                                Style="{StaticResource UniFillIcon}" 
                                Content="{Binding CardIcon}"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right"
                                Width="32" Height="32"
                                Foreground="{DynamicResource PrimaryBrandBrush}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="{Binding CardDescription}"
                           Margin="0,0,0,0"
                           TextWrapping="Wrap" 
                           VerticalAlignment="Bottom" HorizontalAlignment="Left"
                           Foreground="#666666"/>

                <TextBlock Grid.Row="1" Grid.Column="1" 
                           Text="{Binding CardValue}" Margin="0,15,0,0" FontSize="24" FontWeight="Bold"
                           VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </DataTemplate>
    
    <ControlTemplate x:Key="DashboardCardDataGridTemplate">
        <Border Style="{DynamicResource DashboardCardStyle}">
            <DataGrid x:Name="ReadonlyDashboardGrid"
                      ItemsSource="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                      Style="{DynamicResource ReadOnlyDataGridStyle}"
                      RowStyle="{DynamicResource DataGridRowStyle}"
                      ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle}"
                      HorizontalScrollBarVisibility="Hidden">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="C" Width="auto"
                                            ElementStyle="{DynamicResource CheckBoxStyle}"
                                            Binding="{Binding IsConfirmed, UpdateSourceTrigger=PropertyChanged}"
                                            CellStyle="{StaticResource BaseDataGridCellStyle}">
                        <DataGridCheckBoxColumn.HeaderTemplate>
                            <DataTemplate>
                                <CheckBox Style="{DynamicResource CheckBoxStyle}"
                                          IsChecked="{Binding DataContext.IsAllConfirmed,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}"/>
                            </DataTemplate>
                        </DataGridCheckBoxColumn.HeaderTemplate>
                    </DataGridCheckBoxColumn>
                    
                    <DataGridTemplateColumn Header="Operations" Width="auto" CellStyle="{StaticResource LockableCellStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{DynamicResource GridEditButton}"
                                            Command="{Binding DataContext.OpenEditViewCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding .}">
                                        <icon:PackIconMaterial Kind="PencilOutline" Style="{DynamicResource GridButtonIcon}"/>
                                    </Button>
                                    <Button Margin="5 0 0 0" Style="{DynamicResource GridRemoveButton}"
                                            Command="{Binding DataContext.DeleteRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding .}">
                                        <icon:PackIconMaterial Kind="DeleteOutline" Style="{DynamicResource GridButtonIcon}"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </ControlTemplate>
</ResourceDictionary>