<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:AAEICS.Client.Converters">
    
    <Thickness x:Key="CardMarginLeft">0,0,5,10</Thickness>
    <Thickness x:Key="CardMarginCenter">5,0,5,10</Thickness>
    <Thickness x:Key="CardMarginRight">5,0,0,10</Thickness>
    
    <DataTemplate x:Key="DashboardCardDataTemplate">
        <Border Style="{StaticResource DashboardCardStyleFocusable}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> 
                    <RowDefinition Height="*" />    
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />    
                    <ColumnDefinition Width="Auto" /> 
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource DashboardTitleStyle}">
                    <TextBlock Text="{Binding CardTitle}" FontWeight="SemiBold" TextWrapping="Wrap" />
                </Border>

                <ContentControl Grid.Row="0" Grid.Column="1"
                                Style="{StaticResource UniFillIcon}" 
                                Content="{Binding CardIcon}"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right"
                                Width="32" Height="32"
                                Foreground="{DynamicResource PrimaryBrandBrush}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="{Binding CardDescription}"
                           Margin="0,0,0,0"
                           TextWrapping="Wrap" 
                           VerticalAlignment="Bottom" HorizontalAlignment="Left"
                           Foreground="#666666"/>

                <TextBlock Grid.Row="1" Grid.Column="1" 
                           Text="{Binding CardValue}" Margin="0,15,0,0" FontSize="24" FontWeight="Bold"
                           VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </DataTemplate>
    
    <DataTemplate x:Key="DashboardCards">
        <ItemsControl Grid.Row="0" 
                      ItemsSource="{Binding DashboardItems}" 
                      ItemTemplate="{StaticResource DashboardCardDataTemplate}"
                      AlternationCount="4">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid>
                        <UniformGrid.Style>
                            <Style TargetType="UniformGrid">
                                <Setter Property="Columns" Value="4" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=ThisPage, Path=ActualWidth, Converter={x:Static converters:IsLessThanConverter.Instance}, ConverterParameter=900}" Value="True">
                                        <Setter Property="Columns" Value="2" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </UniformGrid.Style>
                    </UniformGrid>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Margin" Value="{StaticResource CardMarginLeft}" />

                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ElementName=ThisPage, Path=ActualWidth, Converter={x:Static converters:IsLessThanConverter.Instance}, ConverterParameter=900}" Value="False" />
                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=(ItemsControl.AlternationIndex)}" Value="1"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Margin" Value="{StaticResource CardMarginCenter}" />
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ElementName=ThisPage, Path=ActualWidth, Converter={x:Static converters:IsLessThanConverter.Instance}, ConverterParameter=900}" Value="False" />
                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=(ItemsControl.AlternationIndex)}" Value="2"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Margin" Value="{StaticResource CardMarginCenter}" />
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ElementName=ThisPage, Path=ActualWidth, Converter={x:Static converters:IsLessThanConverter.Instance}, ConverterParameter=900}" Value="False" />
                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=(ItemsControl.AlternationIndex)}" Value="3"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Margin" Value="{StaticResource CardMarginRight}" />
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ElementName=ThisPage, Path=ActualWidth, Converter={x:Static converters:IsLessThanConverter.Instance}, ConverterParameter=900}" Value="True" />
                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=(ItemsControl.AlternationIndex)}" Value="1"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Margin" Value="{StaticResource CardMarginRight}" />
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ElementName=ThisPage, Path=ActualWidth, Converter={x:Static converters:IsLessThanConverter.Instance}, ConverterParameter=900}" Value="True" />
                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=(ItemsControl.AlternationIndex)}" Value="2"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Margin" Value="{StaticResource CardMarginLeft}" />
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding ElementName=ThisPage, Path=ActualWidth, Converter={x:Static converters:IsLessThanConverter.Instance}, ConverterParameter=900}" Value="True" />
                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=(ItemsControl.AlternationIndex)}" Value="3"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Margin" Value="{StaticResource CardMarginRight}" />
                        </MultiDataTrigger>

                    </Style.Triggers>
                </Style>
            </ItemsControl.ItemContainerStyle>
        </ItemsControl>
    </DataTemplate>
</ResourceDictionary>