<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Controls/Dashboards.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="TabletLayout">
                <Grid x:Name="Card_Grid"
                      VerticalAlignment="Stretch"
                      HorizontalAlignment="Stretch"
                      Background="Transparent">

                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="CG_R1" Height="auto" />
                        <RowDefinition x:Name="CG_R2" Height="*" />
                        <RowDefinition x:Name="CG_R3" Height="*" />
                    </Grid.RowDefinitions>

                    <ItemsControl Grid.Row="0"
                                  ItemsSource="{Binding DashboardItems}"
                                  ItemTemplate="{StaticResource DashboardCardDataTemplate}"
                                  AlternationCount="2">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="{StaticResource CardMarginLeft}" />
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Margin" Value="{StaticResource CardMarginRight}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>

                    <!-- <ContentControl Grid.Row="1" -->
                    <!--                 Template="{DynamicResource DashboardCardDataGridTemplate}" -->
                    <!--                 Content="{Binding IncomingCertificates}" -->
                    <!--                 Margin="0,0,0,10" /> -->
                    
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding IncomingCertificates}"
                              x:Name="membersDataGrid"
                              HorizontalAlignment="Stretch"
                              VerticalScrollBarVisibility="Auto"
          
                              HorizontalScrollBarVisibility="Disabled" 
          
                              EnableColumnVirtualization="False"
          
                              AutoGenerateColumns="False">
    <DataGrid.Columns>
        <DataGridCheckBoxColumn Header="C" Width="Auto" CanUserResize="False" ElementStyle="{StaticResource CheckBoxStyle}">
            <DataGridCheckBoxColumn.HeaderTemplate>
                <DataTemplate>
                    <CheckBox Style="{StaticResource CheckBoxStyle}"/>
                </DataTemplate>
            </DataGridCheckBoxColumn.HeaderTemplate>
        </DataGridCheckBoxColumn>
        
        <DataGridTextColumn Header="ЄДРПОУ" Binding="{Binding Edrpou}" Width="Auto" />
        <DataGridTextColumn Header="Особа, що затвердила" Binding="{Binding ApprovePerson}" Width="Auto" />
        <DataGridTextColumn Header="Дата затвердження" Binding="{Binding ApproveDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto" />
        <DataGridTextColumn Header="Дата реєстрації" Binding="{Binding RegistrationDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto" />
        
        <DataGridTextColumn Header="Місце реєстрації" Binding="{Binding RegistrationPlace}" Width="Auto" />
        
        <DataGridTextColumn Header="Дата початку передачі" Binding="{Binding TransferDateStart, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto" />
        <DataGridTextColumn Header="Дата кінця передачі" Binding="{Binding TransferDateEnd, StringFormat=\{0:dd.MM.yyyy\}}" Width="Auto" />
        <DataGridTextColumn Header="Донор" Binding="{Binding Donor}" Width="Auto" />
        <DataGridTextColumn Header="Отримувач" Binding="{Binding Recipient}" Width="Auto" />
        <DataGridTextColumn Header="Компанія доставки" Binding="{Binding DeliveryCompany}" Width="Auto" />
        
        <DataGridTemplateColumn Header="Operations" IsReadOnly="True" Width="Auto">
            <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource GridEditButton}">
                            <Icon:PackIconMaterial Kind="PencilOutline" Style="{StaticResource GridButtonIcon}"/>
                        </Button>
                        <Button Margin="5 0 0 0" Style="{StaticResource GridRemoveButton}">
                            <Icon:PackIconMaterial Kind="DeleteOutline" Style="{StaticResource GridButtonIcon}"/>
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
    </DataGrid.Columns>
</DataGrid>
                    
                </Grid>
    </DataTemplate>
</ResourceDictionary>